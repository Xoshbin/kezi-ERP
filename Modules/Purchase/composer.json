{
    "name": "jmeryar/purchase",
    "description": "Purchase module for Jmeryar",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "jmeryar/foundation": "*",
        "jmeryar/product": "*",
        "jmeryar/inventory": "*",
        "jmeryar/accounting": "*"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Purchase\\": "app/",
            "Modules\\Purchase\\Database\\Factories\\": "database/factories/",
            "Modules\\Purchase\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Purchase\\Providers\\PurchaseServiceProvider"
            ]
        }
    }
}
