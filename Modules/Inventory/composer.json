{
    "name": "jmeryar/inventory",
    "description": "Inventory module for Jmeryar",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "jmeryar/foundation": "*",
        "jmeryar/product": "*",
        "jmeryar/accounting": "*",
        "brick/money": "^0.10.1"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Inventory\\": "app/",
            "Modules\\Inventory\\Database\\Factories\\": "database/factories/",
            "Modules\\Inventory\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Inventory\\Providers\\InventoryServiceProvider"
            ]
        }
    }
}
