includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:

    paths:
        - app/

    # Level 10 is the highest level
    level: 8

    ignoreErrors:
        # Laravel relationship covariance issues - these are inherent to Laravel's type system
        # and cannot be fixed without breaking Laravel's functionality
        - '#should return.*?static\(.*?\).*?but returns.*?\$this\(.*?\)#'

        # Missing generic types for models without factories or with complex relationships
        # These are acceptable for models that don't need factories or have complex setups
        - '#Class.*?uses generic trait.*?HasFactory but does not specify its types#'
        - '#return type with generic class.*?does not specify its types#'
        - '#has parameter.*?with generic class.*?does not specify its types#'

        # Collection template type resolution issues - PHPStan limitations with mapWithKeys
        - '#Unable to resolve the template type TMapWithKeysKey in call to method#'
        - '#Unable to resolve the template type TMapWithKeysValue in call to method#'
        - '#Method App\\Models\\.*?::searchWithTranslatedLabels\(\) should return.*?but returns#'

#    excludePaths:
#        - ./*/*/FileToBeExcluded.php
