{
    "name": "jmeryar/product",
    "description": "Product module for Jmeryar",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "jmeryar/foundation": "*",
        "spatie/laravel-translatable": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Jmeryar\\Product\\": "app/",
            "Jmeryar\\Product\\Database\\Factories\\": "database/factories/",
            "Jmeryar\\Product\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jmeryar\\Product\\Providers\\ProductServiceProvider"
            ]
        }
    }
}
