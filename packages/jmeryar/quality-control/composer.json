{
    "name": "jmeryar/quality-control",
    "description": "Quality Control module for Jmeryar",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "jmeryar/foundation": "*",
        "jmeryar/manufacturing": "*",
        "jmeryar/inventory": "*"
    },
    "autoload": {
        "psr-4": {
            "Jmeryar\\QualityControl\\": "app/",
            "Jmeryar\\QualityControl\\Database\\Factories\\": "database/factories/",
            "Jmeryar\\QualityControl\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jmeryar\\QualityControl\\Providers\\QualityControlServiceProvider"
            ]
        }
    }
}
