{
    "name": "jmeryar/sales",
    "description": "Sales module for Jmeryar",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "jmeryar/foundation": "*",
        "jmeryar/product": "*",
        "jmeryar/inventory": "*",
        "jmeryar/accounting": "*",
        "barryvdh/laravel-dompdf": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Jmeryar\\Sales\\": "app/",
            "Jmeryar\\Sales\\Database\\Factories\\": "database/factories/",
            "Jmeryar\\Sales\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jmeryar\\Sales\\Providers\\SalesServiceProvider"
            ]
        }
    }
}
