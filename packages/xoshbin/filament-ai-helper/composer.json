{
    "name": "xoshbin/filament-ai-helper",
    "description": "AccounTech Pro AI Helper - A context-aware AI assistant plugin for Filament v4 powered by Google Gemini API",
    "keywords": [
        "laravel",
        "filament",
        "ai",
        "assistant",
        "gemini",
        "accounting",
        "plugin"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "filament/filament": "^4.0",
        "livewire/livewire": "^3.0",
        "illuminate/contracts": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Xoshbin\\FilamentAiHelper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xoshbin\\FilamentAiHelper\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xoshbin\\FilamentAiHelper\\FilamentAiHelperServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
