{
    "name": "kezi/quality-control",
    "description": "Quality Control module for Kezi",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "kezi/foundation": "*",
        "kezi/manufacturing": "*",
        "kezi/inventory": "*"
    },
    "autoload": {
        "psr-4": {
            "Kezi\\QualityControl\\": "app/",
            "Kezi\\QualityControl\\Database\\Factories\\": "database/factories/",
            "Kezi\\QualityControl\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kezi\\QualityControl\\Providers\\QualityControlServiceProvider"
            ]
        }
    }
}
