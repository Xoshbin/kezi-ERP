{
    "name": "kezi/foundation",
    "description": "Foundation module for Kezi",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "bezhansalleh/filament-shield": "^4.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-translatable": "^6.0",
        "brick/money": "^0.10.1",
        "xoshbin/filament-custom-fields": "^0.0.2@beta"
    },
    "autoload": {
        "psr-4": {
