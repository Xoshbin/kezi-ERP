{
    "name": "kezi/sales",
    "description": "Sales module for Kezi",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "kezi/foundation": "*",
        "kezi/product": "*",
        "kezi/inventory": "*",
