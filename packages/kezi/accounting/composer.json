    "description": "Accounting module for Kezi",
    "authors": [
        {
            "name": "Khoshbin",
            "email": "xoshbin@gmail.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^4.0",
        "kezi/foundation": "*",
        "kezi/product": "*",
        "spatie/laravel-translatable": "^6.0",
        "brick/money": "^0.10.1",
        "xoshbin/filament-translatable-select": "^1.0"
    },
    "autoload": {
